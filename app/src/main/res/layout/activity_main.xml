<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="@dimen/content_padding">

    <!-- ── Top bar: identity + settings ──────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layout_top"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User: —"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_title"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Group: —"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_body"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="@dimen/text_size_body"
            android:minHeight="48dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- ── Divider ─────────────────────────────────────────────────────────── -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="@dimen/section_margin"
        app:layout_constraintTop_toBottomOf="@id/layout_top"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Active users label ─────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_users_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ACTIVE USERS"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_size_label"
        android:letterSpacing="0.08"
        android:layout_marginTop="@dimen/section_margin"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ── User list — fills all available vertical space ─────────────────── -->
    <ScrollView
        android:id="@+id/scroll_users"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:fadeScrollbars="true"
        app:layout_constraintTop_toBottomOf="@id/tv_users_label"
        app:layout_constraintBottom_toTopOf="@id/tv_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_users"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• (no users yet)"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_body"
            android:lineSpacingMultiplier="1.5" />
    </ScrollView>

    <!-- ── Status line ────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Initializing…"
        android:textColor="@color/status_ok"
        android:textSize="@dimen/text_size_status"
        android:gravity="center"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"
        app:layout_constraintBottom_toTopOf="@id/btn_ptt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── PTT button ─────────────────────────────────────────────────────── -->
    <Button
        android:id="@+id/btn_ptt"
        android:layout_width="0dp"
        android:layout_height="@dimen/ptt_height"
        android:text="PRESS TO TALK"
        android:textSize="@dimen/text_size_ptt"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="@color/ptt_idle"
        app:layout_constraintBottom_toTopOf="@id/tv_hint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Hint ───────────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Hold to transmit  •  Release to stop"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_size_label"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
